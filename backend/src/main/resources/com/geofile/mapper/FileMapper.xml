<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.geofile.mapper.FileMapper">

    <resultMap id="BaseResultMap" type="com.geofile.pojo.File">
            <id property="id" column="id" />
            <result property="fileName" column="file_name" />
            <result property="fileType" column="file_type" />
            <result property="fileSize" column="file_size" />
            <result property="filePath" column="file_path" />
            <result property="originalName" column="original_name" />
            <result property="storageType" column="storage_type" />
            <result property="uploadTime" column="upload_time" />
            <result property="expireTime" column="expire_time" />
            <result property="downloadCount" column="download_count" />
            <result property="status" column="status" />
            <result property="locationLat" column="location_lat" />
            <result property="locationLng" column="location_lng" />
            <result property="locationRadius" column="location_radius" />
            <result property="regionId" column="region_id" />
            <result property="createdBy" column="created_by" />
            <result property="createdTime" column="created_time" />
            <result property="updatedBy" column="updated_by" />
            <result property="updatedTime" column="updated_time" />
            <result property="deleted" column="deleted" />
    </resultMap>

    <sql id="Base_Column_List">
        id,file_name,file_type,file_size,file_path,original_name,
        storage_type,upload_time,expire_time,download_count,status,
        location_lat,location_lng,location_radius,region_id,created_by,
        created_time,updated_by,updated_time,deleted
    </sql>
</mapper>
