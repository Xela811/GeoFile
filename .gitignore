# IDEA 配置文件
backend/.idea/
backend/*.iml

# 后端编译产物
backend/target/

backend/*.class
backend/**/test/
backend/*Test.java

# 前端依赖与产物
frontend/node_modules/
frontend/dist/

# 日志文件
logs/
*.log

# 系统文件
.DS_Store

# --- 补充部分 ---

# 操作系统临时文件
*.swp
*.thumbs.db
desktop.ini

# 后端补充
# 忽略 Maven 运行时的本地仓库拷贝（如果有）
.mvn/wrapper/maven-wrapper.jar
# 忽略本地开发环境的配置文件（如果你打算按之前的建议使用 local 配置）
backend/src/main/resources/application-local.yml
backend/src/main/resources/application-prod.yml

# 前端补充
# 忽略本地环境变量文件
frontend/.env.local
frontend/.env.*.local
# 忽略 npm 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 数据库相关（如果你本地有临时导出的 SQL 备份）
!/doc/*.sql  # 但不要忽略 doc 目录下的初始化脚本
